# ============================================================
# Frontend environment variables
# Copy to frontend/.env and fill in real values.
# NEVER commit frontend/.env to version control.
# ============================================================

# ----------------------------------------------------------
# API Authentication (REQUIRED)
# Must match API_KEY in backend/.env exactly.
# Used by Nginx at container startup to inject the header
# server-side — never exposed to the browser.
# ----------------------------------------------------------
API_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET
