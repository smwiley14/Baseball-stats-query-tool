# ============================================================
# Backend environment variables
# Copy to backend/.env and fill in real values.
# NEVER commit backend/.env to version control.
# ============================================================

# ----------------------------------------------------------
# API Authentication (REQUIRED)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------
API_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

# ----------------------------------------------------------
# OpenAI (REQUIRED)
# ----------------------------------------------------------
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY

# ----------------------------------------------------------
# PostgreSQL — Admin user
# Used by the Postgres container to initialise the database.
# ----------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=REPLACE_WITH_ADMIN_DB_USER
POSTGRES_PASSWORD=REPLACE_WITH_ADMIN_DB_PASSWORD
POSTGRES_DB=retrosheet

# ----------------------------------------------------------
# PostgreSQL — Read-only app user (REQUIRED)
# The backend connects as this user (SELECT only).
# Created automatically on first Postgres container boot.
# Generate password: python -c "import secrets; print(secrets.token_hex(24))"
# ----------------------------------------------------------
POSTGRES_READONLY_USER=REPLACE_WITH_READONLY_DB_USER
POSTGRES_READONLY_PASSWORD=REPLACE_WITH_READONLY_DB_PASSWORD

# ----------------------------------------------------------
# LangChain / LangSmith tracing (optional)
# ----------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=Baseball-Query-Tool
