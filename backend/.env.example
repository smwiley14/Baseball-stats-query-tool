# Copy this file to backend/.env and fill in real values.
# backend/.env is used by docker-compose for the backend, frontend, and postgres services.

# --- API auth ---
# Strong random secret required by clients in the X-API-Key header.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# --- Postgres: admin credentials (used only for schema init / migrations) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
# POSTGRES_DB is required by the official postgres image to name the initial database.
POSTGRES_DB=
# POSTGRES_DATABASE is read by the app code as a fallback alias for POSTGRES_DB — keep both in sync.
POSTGRES_DATABASE=

# --- Postgres: read-only application credentials ---
# The backend prefers these over POSTGRES_USER/PASSWORD for all query execution.
# Created automatically on first container init by db/02-readonly-user.sh.
POSTGRES_READONLY_USER=
POSTGRES_READONLY_PASSWORD=

# --- LLM / tracing ---
OPENAI_API_KEY=
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT="Baseball-Query-Tool"

# --- CORS ---
# Comma-separated list of allowed frontend origins. Falls back to localhost-only if unset.
ALLOWED_ORIGINS=
