# Copy this file to .env and fill in real values.
# Used for local (non-Docker) development — running scripts/tests directly from the repo root.
# For the Docker Compose deployment, see backend/.env.example instead.

OPENAI_API_KEY=
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT="Baseball-Query-Tool"

# --- Postgres: read-only application credentials (preferred by DBConnector) ---
POSTGRES_READONLY_USER=
POSTGRES_READONLY_PASSWORD=

# --- Postgres: admin credentials (fallback if readonly creds are unset) ---
POSTGRES_HOST=localhost
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=5433
POSTGRES_DATABASE=

# --- API auth (only needed if running the backend locally with auth enabled) ---
API_KEY=
