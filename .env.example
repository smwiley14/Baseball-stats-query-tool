# ============================================================
# Baseball Stats Query Tool — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# API Authentication (REQUIRED in production)
# ----------------------------------------------------------
# Generate a strong random key, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

# ----------------------------------------------------------
# PostgreSQL Database (ALL fields REQUIRED)
# ----------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Admin user — used only by the Postgres container to initialise the DB.
POSTGRES_USER=REPLACE_WITH_ADMIN_DB_USER
POSTGRES_PASSWORD=REPLACE_WITH_ADMIN_DB_PASSWORD
POSTGRES_DB=retrosheet

# Read-only app user — the backend connects as this user (SELECT only).
# Created automatically on first Postgres container boot via db/02-readonly-user.sh.
POSTGRES_READONLY_USER=REPLACE_WITH_READONLY_DB_USER
POSTGRES_READONLY_PASSWORD=REPLACE_WITH_READONLY_DB_PASSWORD

# ----------------------------------------------------------
# CORS — comma-separated list of allowed frontend origins
# (REQUIRED in production — leave unset for localhost-only dev)
# ----------------------------------------------------------
# Example: ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
ALLOWED_ORIGINS=

# ----------------------------------------------------------
# OpenAI
# ----------------------------------------------------------
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY

# ----------------------------------------------------------
# LangChain / LangSmith tracing (optional)
# ----------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=Baseball-Query-Tool
